{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "henefen",
  "main": "src/index.js",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "henefen-db",
      "database_id": "REMPLACE_PAR_L_ID_DE_TA_BASE_D1"
    }
  ]
}
